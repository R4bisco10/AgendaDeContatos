<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="agendadeContatos.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Agenda de Contatos</title>
</head>
<body>
    <div class="cabecalho"><h1 class="h1">Agenda de Contatos</h1></div>
    <div class="container1">
        <div class="box1">
            <h1>Cadastrar</h1>
            <form>
                <label for="nome"><b>Nome</b></label>
                <input type="text" id="nome" placeholder="Digite um nome">
                <label for="email"><b>E-mail</b></label>
                <input type="email" id="email" placeholder="Digite um email">
                <label for="numero"><b>Número</b></label>
                <input type="text" id="numero" placeholder="Digite um número">
                <div id="mensagem"></div>
                <button class="buttonCadastrar"><b>Cadastrar</b></button>
            </form>
        </div>
        <div class="box2">
            <div>
                <h1>Contatos</h1>
                <input type="text" id="buscar" placeholder="Buscar">
            </div>
            <div class="box3"></div>
        </div>
    </div>
    <script src="agendaDeContatos.js"></script>
</body>
</html>
